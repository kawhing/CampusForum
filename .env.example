# 匿名问答平台配置文件

# MongoDB配置
MONGODB_URI=mongodb://mongodb:27017/anon-qa

# JWT配置
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRES_IN=7d

# 后端配置
PORT=5000
NODE_ENV=production

# 前端配置
REACT_APP_API_URL=/api

# 管理员账户（首次启动时自动创建，如已存在则跳过）
ADMIN_EMAIL=admin@campus.edu
ADMIN_PASSWORD=Admin123456
ADMIN_USERNAME=admin
ALLOW_ADMIN_PASSWORD_SYNC=true
ALLOW_ADMIN_SYNC_WHEN_BLOCKED=false

# 可选：文本安全/心理风险小模型服务
SAFETY_MODEL_URL=http://safety-model:8088
SAFETY_MODEL_NAME=uer/roberta-base-chinese-cluecorpussmall
SAFETY_MODEL_DEVICE=cpu
