# 校园论坛配置文件

# MySQL配置
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=campus_forum
MYSQL_USER=campusforum
MYSQL_PASSWORD=campusforum123

# Spring Boot应用配置
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/campus_forum?useSSL=false&serverTimezone=UTC&characterEncoding=utf8mb4&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# 文件上传配置
FILE_UPLOAD_PATH=/var/lib/campusforum/uploads
FILE_UPLOAD_MAX_SIZE=20971520

# 应用配置
SERVER_PORT=8080
SPRING_APPLICATION_NAME=CampusForum

# 时区
TZ=Asia/Shanghai

# 日志级别
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_CAMPUSFORUM=DEBUG
